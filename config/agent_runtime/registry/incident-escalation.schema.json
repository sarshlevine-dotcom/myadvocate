{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myadvocate.local/schemas/incident-escalation.schema.json",
  "title": "Incident Escalation",
  "type": "object",
  "required": [
    "incident_id",
    "owner_agent_id",
    "severity",
    "detected_at",
    "impact",
    "containment_status",
    "next_actions",
    "escalated_to"
  ],
  "properties": {
    "incident_id": { "type": "string" },
    "owner_agent_id": { "type": "string" },
    "severity": { "type": "string", "enum": ["medium", "high", "critical"] },
    "detected_at": { "type": "string", "format": "date-time" },
    "impact": { "type": "string" },
    "containment_status": { "type": "string" },
    "next_actions": { "type": "array", "items": { "type": "string" } },
    "escalated_to": { "type": "array", "items": { "type": "string" } },
    "founder_notice_required": { "type": "boolean" }
  }
}
