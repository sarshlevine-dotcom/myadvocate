#!/usr/bin/env bash
# pre-commit — Git pre-commit hook
# Runs ESLint on all staged .ts/.tsx/.js files before each commit.
#
# Install: bash scripts/install-hooks.sh
# Or manually: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -euo pipefail

echo "🔍 Pre-commit: running ESLint on staged files..."

# Get all staged .ts, .tsx, .js, .jsx files — exclude dirs ESLint ignores
staged_files=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '\.(ts|tsx|js|jsx)$' \
  | grep -Ev '^(automation|scripts)/' \
  || true)

if [[ -z "$staged_files" ]]; then
  echo "  No JS/TS files staged — skipping lint."
  exit 0
fi

echo "  Staged files:"
echo "$staged_files" | sed 's/^/    /'
echo ""

# Run ESLint on the staged files
if npx eslint $staged_files --max-warnings=0 --no-warn-ignored 2>&1; then
  echo ""
  echo "✅ ESLint passed."
else
  echo ""
  echo "❌ ESLint found issues. Fix them before committing."
  echo ""
  echo "Tip: Run 'npm run lint' to see all issues."
  echo "     Run 'npx eslint --fix <file>' to auto-fix where possible."
  exit 1
fi
