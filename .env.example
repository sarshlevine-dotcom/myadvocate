# Supabase — get from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — get from dashboard.stripe.com > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
# Per-case $13 one-time payment — create in Stripe Dashboard > Products, copy Price ID
STRIPE_PER_CASE_PRICE_ID=price_your_id_here
# Subscription price IDs — create in Stripe Dashboard > Products
STRIPE_PRICE_ID_MONTHLY=price_your_id_here
STRIPE_PRICE_ID_ONE_TIME=price_your_id_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upstash Redis — required for rate limiting (MA-SEC-002 P15)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXyourtoken

# Notion — required for automation/daily.js sync
# Get from: notion.so/my-integrations > your integration > Internal Integration Token
NOTION_API_KEY=secret_...
# Database ID from Notion task board URL: notion.so/workspace/<DATABASE_ID>?v=...
NOTION_TASKS_DB_ID=your-notion-database-id-here
# Waitlist signal monitor page ID (pre-filled — do not change)
NOTION_WAITLIST_PAGE_ID=3212eb8be06181c0b7a9f75883a2f294

# Beehiiv — required for waitlist monitoring (MA-IG-001, MA-LANG-001)
# Get API key from: app.beehiiv.com > Settings > API
# Get publication ID from: app.beehiiv.com > Settings > Publication — looks like pub_xxxxxxxx
BEEHIIV_API_KEY=your-beehiiv-api-key-here
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx

# YMYL Review Notifications (MA-SEC-002 P27)
# Google Workspace SMTP — use an App Password, not your account password
# Generate at: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@getmyadvocate.org
SMTP_PASS=your-google-workspace-app-password

# Reviewer email addresses — both receive new artifact notifications; Sarsh-only for capacity alerts
KATE_EMAIL=kate@example.com
SARSH_EMAIL=sarsh@example.com
